      "settings": {
        "fontStyle": "",
        "foreground": "#9AA83A"
      }
    },
    {
      "name": "Tag Other",
      "scope": "meta.tag.other, entity.name.tag.style, entity.name.tag.script, meta.tag.block.script, source.js.embedded punctuation.definition.tag.html, source.css.embedded punctuation.definition.tag.html",
      "settings": {
        "fontStyle": "",
        "foreground": "#9872A2"
