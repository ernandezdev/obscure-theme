      "settings": {
        "fontStyle": "",
        "foreground": "#9872A2"
      }
    },
    {
      "name": "Keyword Control / Special",
      "scope": [
        "keyword.control",
        "keyword.operator.new.cpp",
        "keyword.operator.delete.cpp",
        "keyword.other.using",
        "keyword.other.directive.using",
        "keyword.other.operator"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#9872A2"
      }
    },
    {
      "name": "Tag",
      "scope": "meta.tag",
      "settings": {
        "fontStyle": "",
        "foreground": "#D0B344"
      }
