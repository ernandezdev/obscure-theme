{
  "name": "obscure-theme",
  "displayName": "Obscure Theme",
  "description": "A focused collection of dark VS Code themes with matching file icon themes.",
  "version": "0.2.1",
  "publisher": "ernandezdev",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "syntax",
    "minimal",
    "icons",
    "dark-theme",
    "color-theme"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Obscure Noir",
        "uiTheme": "vs-dark",
        "path": "./themes/obscure-noir-color-theme.json"
      },
      {
        "label": "Obscure Ember",
        "uiTheme": "vs-dark",
        "path": "./themes/obscure-ember-color-theme.json"
      },
      {
        "label": "Obscure Mist",
        "uiTheme": "vs-dark",
        "path": "./themes/obscure-mist-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "obscure-file-icons",
        "label": "Obscure File Icons",
        "path": "./icons/obscure-file-icons-icon-theme.json"
      },
      {
        "id": "obscure-file-icons-mono",
        "label": "Obscure File Icons Mono",
        "path": "./icons/obscure-file-icons-mono-icon-theme.json"
      }
    ]
  }
}
